{
  "name": "ecom",
  "version": "1.0.0",
  "description": "ecommerce rest api",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm start --prefix ./client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "sonarqube": "sonar-scanner",
    "test": "npm run test:backend; b=$?; npm run test:frontend; f=$?; [ $b -eq 0 ] && [ $f -eq 0 ]",
    "test:frontend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.frontend.config.js",
    "test:backend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.backend.config.js",
    "test:integration:backend": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration.config.js",
    "test:security": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.security.config.js",
    "test:integration:frontend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.frontend.integration.config.js",
    "test:e2e": "playwright test",
    "test:load": "cd tests/loadtest && node runner.js",
    "test:soak": "cd tests/soak && node soak-runner.js",
    "test:spike:flash": "cross-env K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_EXPORT=report-flash.html k6 run tests/spike/flash-sale-spike.test.js",
    "test:spike:login": "cross-env K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_EXPORT=report-login.html k6 run tests/spike/login-surge-spike.test.js",
    "test:spike:search": "cross-env K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_EXPORT=report-search.html k6 run tests/spike/search-spike.test.js",
    "test:spike:category": "cross-env K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_EXPORT=report-category.html k6 run tests/spike/category-spike.test.js",
    "test:spike:checkout": "cross-env K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_EXPORT=report-checkout.html k6 run tests/spike/checkout-spike.test.js",
    "test:spike:full": "cross-env K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_EXPORT=report-full.html k6 run tests/spike/full-scenario-spike.test.js",
    "test:spike:all": "npm run test:spike:flash && npm run test:spike:login && npm run test:spike:search && npm run test:spike:category && npm run test:spike:checkout"
  },
  "keywords": [],
  "author": "RP",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "braintree": "^3.22.0",
    "colors": "^1.4.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-formidable": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^8.1.2",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.3",
    "react-icons": "^5.0.1",
    "slugify": "^1.6.6",
    "supertest": "^7.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "@playwright/test": "^1.44.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.12.12",
    "babel-jest": "^29.7.0",
    "cross-env": "^10.1.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fixed-jsdom": "^0.0.11",
    "mongodb-memory-server": "^11.0.1",
    "msw": "^2.12.10",
    "sonarqube-scanner": "^3.3.0",
    "supertest": "^7.2.2",
    "undici": "^7.22.0"
  },
  "msw": {
    "workerDirectory": [
      "client/public"
    ]
  }
}